<idea-plugin>
  <id>io.obez.themes</id>
  <name>Matugen</name>
  <version>1.0.0</version>
  <vendor>Matugen Theme</vendor>

  <description><![CDATA[
      An intellij theme for applying matugen colors.
    ]]></description>

  <!-- please see https://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/build_number_ranges.html for description -->
  <idea-version since-build="173.0"/>

  <!-- please see https://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
       on how to target different products -->
  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Add your extensions here -->
    <themeProvider id="io.obez.themes.matugen" path="/Matugen.theme.json"/>
    <themeProvider id="io.obez.themes.varda" path="/Varda.theme.json"/>
  </extensions>

</idea-plugin>